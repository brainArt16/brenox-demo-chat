# Production — set in Coolify UI (do not commit secrets).

COMPOSE_PROJECT_NAME=brenox-demo-chat
DEPLOY_RESTART=always
PORT=8080

# Brenox engine (server-side + browser)
BRENOX_API_URL=https://api.breno-x.com
BRENOX_API_KEY=bx_test_your_sandbox_key

# Baked into the frontend at image build time
VITE_BRENOX_API_URL=https://api.breno-x.com
VITE_DEMO_API_URL=
VITE_APP_BASE_PATH=/
