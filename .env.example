# Brenox engine (used by embed demo server)
BRENOX_API_URL=http://localhost:8080
BRENOX_API_KEY=bx_test_your_sandbox_key

# Frontend — Brenox API for BrenoxClient (WebSocket + REST)
VITE_BRENOX_API_URL=http://localhost:8080

# Leave empty to use Vite proxy (/api -> demo server)
VITE_DEMO_API_URL=

VITE_APP_BASE_PATH=/

# Embed demo server port
DEMO_SERVER_PORT=3001

# WebRTC ICE servers (JSON array). Default: Google STUN. Add TURN for production.
# VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
